# Oraya Web — environment variable names only (no secrets).
# Copy to `.env.local`, fill values, and never commit `.env.local`.
# Vercel production/staging env is separate; mirror keys there as needed.
# See README.md for local testing notes.

# --- Supabase (browser + server) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: required for admin APIs, media, pricing, bookings server paths, cron sync, etc.
# Without this key, `supabase-admin` routes fail locally with errors like "supabaseKey is required".
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email) ---
RESEND_API_KEY=
# Optional: not read by current code paths; "from" is hardcoded in lib/send-*-email.ts. Reserved for future use.
RESEND_FROM_EMAIL=

# --- URLs ---
# Absolute site base for links in emails and booking flows (falls back to lib/brand SITE_URL if unset).
NEXT_PUBLIC_SITE_URL=

# --- Auth & automation ---
BOOKING_ACTION_SECRET=
CRON_SECRET=
ADMIN_SECRET=

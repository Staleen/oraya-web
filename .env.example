# Oraya Web — environment variable names with placeholder values only (NO REAL SECRETS).
# Copy to `.env.local`, replace each `replace_with_*` placeholder with the real value, and never commit `.env.local`.
# Vercel Production/Preview env is configured separately in the Vercel dashboard — mirror keys there as needed.
# Full per-variable docs: docs/system/ENVIRONMENT_MAP.md
# See README.md for local testing notes.

# --- Supabase (browser + server) ---
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=replace_with_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_supabase_anon_public_key

# Server-only: required for admin APIs, media, pricing, bookings server paths, cron sync, etc.
# Without this key, `supabase-admin` routes fail locally with errors like "supabaseKey is required".
# From: Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

# --- Resend (transactional email) ---
# From: resend.com → Dashboard → API Keys
RESEND_API_KEY=replace_with_resend_api_key

# Optional: NOT read by current code paths; "from" is hardcoded as `FROM_EMAIL` in lib/send-*-email.ts.
# Reserved for future use — setting it today has no effect.
RESEND_FROM_EMAIL=replace_with_verified_resend_sender_email

# --- URLs ---
# Absolute site base for links in emails and booking flows (falls back to lib/brand SITE_URL if unset).
# Local: http://localhost:3000 — Preview: the Vercel preview URL — Production: https://stayoraya.com
NEXT_PUBLIC_SITE_URL=replace_with_site_origin_url

# --- Auth & automation (server-only) ---
# Generate strong randoms (≥32 bytes), e.g. `openssl rand -base64 32`. Use a DIFFERENT value for each.

# HMAC secret for signing/verifying booking action + view tokens (lib/booking-action-token.ts). No fallback.
BOOKING_ACTION_SECRET=replace_with_random_32_byte_secret

# Bearer token Vercel Cron uses to authorize GET /api/cron/calendar-sync. No fallback.
CRON_SECRET=replace_with_random_32_byte_secret

# HMAC key for the signed admin session cookie + bearer fallback for /api/admin/*. No fallback.
ADMIN_SECRET=replace_with_random_32_byte_secret
